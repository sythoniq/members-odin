<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Make Posts</title>
  </head>
  <body>
    <form action="/messages/new" method="post">
      <h2>Create Post</h2>
      <label for="message-title">Message Title</label>
      <input type="text" id="message-title" name="messagetitle" />
      <label for="message">Message</label>
      <input type="text" id="message" name="message" />
      <button type="submit">Create</button>
    </form>
  </body>
</html>
